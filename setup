#!/bin/bash
################################################################################
# Wine Proton Multi-Launcher Setup Script
# Purpose: Manage multiple game launchers (EA Desktop, GOG Galaxy, Epic Games,
#          Ubisoft Connect, Amazon Games, Legacy Games) via Proton/Wine
# Features:
#   - Centralized app registry for easy launcher management
#   - Generic install/uninstall/launch functions
#   - Dynamic installer downloading with caching
#   - Desktop shortcut creation and management
#   - Batch operations (install-all, list)
################################################################################

# Note: We do NOT use 'set -e' to allow batch operations to continue on errors

# ============================================================================
# CONFIGURATION
# ============================================================================

WINE_DIR="${HOME}/.wine-gaming"
WINEPREFIX="${WINE_DIR}/prefix"
PROTON_DIR="${WINE_DIR}/proton-ge"
BACKUP_DIR="${WINE_DIR}/backup"
CACHE_DIR="${HOME}/.cache/wine-installers"
BIN_DIR="${WINE_DIR}/bin"
APPS_DIR="${HOME}/.local/share/applications"

export WINEPREFIX WINEARCH=win64

# Ensure necessary directories exist
mkdir -p "$WINE_DIR" "$BACKUP_DIR" "$CACHE_DIR" "$BIN_DIR" "$APPS_DIR"

# ============================================================================
# APP REGISTRY - Define all supported launchers
# ============================================================================
# Format: [app-key]="name|exe-relative-path|install-url|uninstall-path1|uninstall-path2|..."
# The registry maps each launcher to its metadata for dynamic operations
# Add new launchers by simply adding entries below
#
declare -A APP_REGISTRY=(
    [ea-desktop]="EA Desktop|Program Files/Electronic Arts/EA Desktop/EA Desktop/EADesktop.exe|https://origin-a.akamaihd.net/EA-Desktop-Client-Download/installer/Pc/EAappInstaller.exe|Program Files/Electronic Arts|AppData/Local/Electronic Arts|AppData/Roaming/Electronic Arts"
    
    [gog-galaxy]="GOG Galaxy|Program Files (x86)/GOG Galaxy/GalaxyClient.exe|https://cdn.gog.com/Open/GOG%20Galaxy/GOG_Galaxy_2.0.exe|Program Files (x86)/GOG Galaxy|AppData/Local/GOG.com|AppData/Roaming/GOG.com"
    
    [epic-games]="Epic Games Launcher|ProgramData/Epic/EpicGamesLauncher/Data/Update/Install/Portal/Binaries/Win64/EpicGamesLauncher.exe|https://launcher-public-service-prod.ol.epicgames.com/launcher/api/installer/download/EpicGamesLauncherInstaller.msi|Program Files/Epic Games|AppData/Local/EpicGamesLauncher|ProgramData/Epic"
    
    [ubisoft-connect]="Ubisoft Connect|Program Files/Ubisoft/Ubisoft Game Launcher/upc.exe|https://ubisoftconnect.com/en-US/downloads|Program Files/Ubisoft|AppData/Local/Ubisoft"
    
    [amazon-games]="Amazon Games|Program Files/Amazon Games/Amazon Games App/AmazonGamesApp.exe|https://amazon-games-launcher.s3.amazonaws.com/AmazonGamesSetup.exe|Program Files/Amazon Games|AppData/Local/Amazon Games"
    
    [legacy-games]="Legacy Games|Program Files/Legacy Games/Legacy Games/Legacy.exe|https://legacy.games/download|Program Files/Legacy Games|AppData/Local/Legacy Games"
)

# ============================================================================
# UTILITY FUNCTIONS
# ============================================================================

# Print colored output
print_info() { echo -e "\033[1;36m[INFO]\033[0m $1"; }
print_error() { echo -e "\033[1;31m[ERROR]\033[0m $1" >&2; }
print_success() { echo -e "\033[1;32m[SUCCESS]\033[0m $1"; }
print_warning() { echo -e "\033[1;33m[WARN]\033[0m $1"; }

# Check if Proton is installed
check_proton() {
    if [ ! -x "$PROTON_DIR/proton" ]; then
        print_error "Proton not found at $PROTON_DIR. Run: $0 install-proton"
        return 1
    fi
    return 0
}

# ============================================================================
# APP REGISTRY FUNCTIONS
# ============================================================================

# Parse app registry entry into variables
# Usage: parse_app_config "app-key"
# Sets global variables: APP_NAME, APP_EXE, APP_URL, APP_UNINSTALL_PATHS
parse_app_config() {
    local app_key="$1"
    
    if [ -z "${APP_REGISTRY[$app_key]}" ]; then
        print_error "Unknown app: $app_key"
        return 1
    fi
    
    IFS='|' read -r APP_NAME APP_EXE APP_URL APP_UNINSTALL_PATHS <<< "${APP_REGISTRY[$app_key]}"
    
    return 0
}

# Find app executable in Wine prefix (searches if hardcoded path doesn't exist)
# Usage: find_app_exe "app-key"
# Returns: absolute path to exe, or empty string if not found
find_app_exe() {
    local app_key="$1"
    parse_app_config "$app_key" || return 1
    
    local exe_filename=$(basename "$APP_EXE")
    local primary_path="$WINEPREFIX/pfx/drive_c/$APP_EXE"
    
    # Try primary path first
    if [ -f "$primary_path" ]; then
        echo "$primary_path"
        return 0
    fi
    
    # Search for exe in Wine prefix if primary path doesn't exist
    local found=$(find "$WINEPREFIX/pfx/drive_c" -name "$exe_filename" -type f 2>/dev/null | head -1)
    if [ -n "$found" ]; then
        echo "$found"
        return 0
    fi
    
    return 1
}

# List all registered applications with install status
list_apps() {
    print_info "Registered Game Launchers:"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    
    local count=0
    local installed=0
    for app_key in "${!APP_REGISTRY[@]}"; do
        parse_app_config "$app_key" || continue
        ((count++))
        
        # Check if app is installed (search dynamically)
        if find_app_exe "$app_key" >/dev/null 2>&1; then
            echo "✓ $app_key           - $APP_NAME (INSTALLED)"
            ((installed++))
        else
            echo "✗ $app_key           - $APP_NAME"
        fi
    done
    
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "Total registered apps: $count | Installed: $installed | Remaining: $((count - installed))"
}

# Check for available installers in ./installers directory
# Usage: find_local_installer "app-key"
# Returns: path to installer in ./installers, or empty string if not found
find_local_installer() {
    local app_key="$1"
    local script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local installers_dir="$script_dir/installers"
    local result=""
    
    if [ ! -d "$installers_dir" ]; then
        return 1
    fi
    
    # Search for common installer patterns based on app key
    case "$app_key" in
        ea-desktop)
            result=$(find "$installers_dir" -maxdepth 1 \( -iname "*EAapp*.exe" -o -iname "*origin*.exe" \) 2>/dev/null | head -1)
            ;;
        gog-galaxy)
            result=$(find "$installers_dir" -maxdepth 1 -iname "*galaxy*.exe" 2>/dev/null | head -1)
            ;;
        epic-games)
            result=$(find "$installers_dir" -maxdepth 1 \( -iname "*epic*.msi" -o -iname "*epic*.exe" \) 2>/dev/null | head -1)
            ;;
        ubisoft-connect)
            result=$(find "$installers_dir" -maxdepth 1 \( -iname "*ubisoft*.exe" -o -iname "*upc*.exe" \) 2>/dev/null | head -1)
            ;;
        amazon-games)
            result=$(find "$installers_dir" -maxdepth 1 -iname "*amazon*.exe" 2>/dev/null | head -1)
            ;;
        legacy-games)
            result=$(find "$installers_dir" -maxdepth 1 -iname "*legacy*.exe" 2>/dev/null | head -1)
            ;;
        *)
            return 1
            ;;
    esac
    
    if [ -n "$result" ]; then
        echo "$result"
        return 0
    fi
    return 1
}

# List available installers in ./installers directory
list_installers() {
    local script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local installers_dir="$script_dir/installers"
    
    if [ ! -d "$installers_dir" ]; then
        print_warning "No ./installers directory found"
        return 1
    fi
    
    local count=$(find "$installers_dir" -maxdepth 1 -type f \( -iname "*.exe" -o -iname "*.msi" \) 2>/dev/null | wc -l)
    
    if [ $count -eq 0 ]; then
        print_warning "No installers found in ./installers"
        return 1
    fi
    
    print_info "Available installers in ./installers:"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    find "$installers_dir" -maxdepth 1 -type f \( -iname "*.exe" -o -iname "*.msi" \) 2>/dev/null | while read -r file; do
        echo "  $(basename "$file")"
    done
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "Total: $count installer(s)"
}

# ============================================================================
# INSTALLER MANAGEMENT
# ============================================================================

# Download installer for an app with caching support
# Usage: download_installer "app-key"
# Returns: path to installer (cached or newly downloaded)
download_installer() {
    local app_key="$1"
    
    parse_app_config "$app_key" || return 1
    
    # Extract filename from URL
    local filename=$(basename "${APP_URL}" | cut -d'?' -f1)
    local cache_path="$CACHE_DIR/$filename"
    
    # Return cached copy if it exists
    if [ -f "$cache_path" ]; then
        print_info "Using cached installer: $filename"
        echo "$cache_path"
        return 0
    fi
    
    print_info "Downloading installer for $APP_NAME..."
    print_info "Source: $APP_URL"
    
    if ! wget -q --show-progress -O "$cache_path" "$APP_URL"; then
        print_error "Failed to download installer from $APP_URL"
        rm -f "$cache_path"
        return 1
    fi
    
    print_success "Installer downloaded: $cache_path"
    echo "$cache_path"
    return 0
}

# ============================================================================
# APP INSTALLATION & REMOVAL
# ============================================================================

# Generic install function using Proton
# Usage: install_app "app-key" [installer_path]
install_app() {
    local app_key="$1"
    local custom_installer="$2"
    
    parse_app_config "$app_key" || return 1
    
    check_proton || return 1
    
    # Determine installer path
    local installer_path
    if [ -n "$custom_installer" ] && [ -f "$custom_installer" ]; then
        installer_path="$custom_installer"
        print_info "Using custom installer: $installer_path"
    else
        installer_path=$(download_installer "$app_key") || return 1
    fi
    
    print_info "Installing $APP_NAME via Proton..."
    
    # Setup Proton environment
    export STEAM_COMPAT_DATA_PATH="$WINEPREFIX"
    export STEAM_COMPAT_CLIENT_INSTALL_PATH="$WINE_DIR/steam-root"
    mkdir -p "$WINE_DIR/steam-root"
    
    # Run installer
    if "$PROTON_DIR/proton" run "$installer_path"; then
        print_success "$APP_NAME installed successfully"
        
        # Auto-create shortcut
        if create_shortcut "$app_key"; then
            print_success "Desktop shortcut created"
        fi
        
        return 0
    else
        print_error "Installation of $APP_NAME failed"
        return 1
    fi
}

# Generic uninstall function
# Usage: uninstall_app "app-key"
uninstall_app() {
    local app_key="$1"
    
    parse_app_config "$app_key" || return 1
    
    print_info "Uninstalling $APP_NAME..."
    
    local pfx_dir="$WINEPREFIX/pfx"
    local removed_count=0
    
    # Read uninstall paths and remove them
    # APP_UNINSTALL_PATHS contains remaining fields after name|exe|url
    IFS='|' read -r -a paths <<< "$APP_REGISTRY[$app_key]"
    
    # Skip first 3 fields (name, exe, url) and process uninstall paths
    for ((i=3; i<${#paths[@]}; i++)); do
        local uninstall_path="${paths[$i]}"
        local full_path="$pfx_dir/drive_c/$uninstall_path"
        
        if [ -e "$full_path" ]; then
            print_info "Removing: $uninstall_path"
            rm -rf "$full_path"
            ((removed_count++))
        fi
    done
    
    if [ $removed_count -gt 0 ]; then
        print_success "$APP_NAME uninstalled ($removed_count paths removed)"
        
        # Auto-remove shortcut
        remove_shortcut "$app_key" || true
        
        return 0
    else
        print_warning "$APP_NAME not found in prefix (already uninstalled?)"
        return 0
    fi
}

# ============================================================================
# APP LAUNCHING
# ============================================================================

# Generic launch function with Proton or Wine fallback
# Usage: launch_app "app-key"
launch_app() {
    local app_key="$1"
    
    parse_app_config "$app_key" || return 1
    
    local exe_path=$(find_app_exe "$app_key")
    if [ -z "$exe_path" ]; then
        print_error "$APP_NAME not installed. Run: $0 install $app_key"
        return 1
    fi
    
    local exe_dir=$(dirname "$exe_path")
    local exe_bin=$(basename "$exe_path")
    
    print_info "Launching $APP_NAME..."
    
    if [ -x "$PROTON_DIR/proton" ]; then
        # Launch with Proton
        export STEAM_COMPAT_DATA_PATH="$WINEPREFIX"
        export STEAM_COMPAT_CLIENT_INSTALL_PATH="$WINE_DIR/steam-root"
        export PROTON_LOG=1
        export PROTON_LOG_DIR="$WINE_DIR"
        export DXVK_HUD=0
        export VKD3D_SHADER_VERBOSE=0
        export WINEDLLOVERRIDES="winemenubuilder.exe=d"
        
        # GPU optimizations for launchers with embedded browsers (EA, Epic, etc)
        export MESA_GL_VERSION_OVERRIDE=4.5
        export __GL_SHADER_DISK_CACHE=1
        export __GL_THREADED_OPTIMIZATION=1
        
        cd "$exe_dir"
        "$PROTON_DIR/proton" run "$exe_bin" --no-sandbox \
            --disable-gpu-sandbox \
            --disable-software-rasterizer \
            --disable-dev-shm-usage \
            --disable-setuid-sandbox \
            --in-process-gpu &
    else
        # Fallback to Wine
        print_warning "Proton not available, using Wine fallback"
        export WINEDEBUG=-all
        export WINEPREFIX="$WINEPREFIX/pfx"
        
        cd "$exe_dir"
        wine "$exe_bin" &
    fi
    
    print_success "$APP_NAME launched (PID: $!)"
}

# ============================================================================
# DESKTOP SHORTCUTS
# ============================================================================

# Create a .desktop shortcut for launching an app
# Usage: create_shortcut "app-key" [display_name]
create_shortcut() {
    local app_key="$1"
    local display_name="${2:-}"
    
    parse_app_config "$app_key" || return 1
    
    local exe_path=$(find_app_exe "$app_key")
    if [ -z "$exe_path" ]; then
        print_warning "$APP_NAME not installed yet, skipping shortcut creation"
        return 1
    fi
    
    display_name="${display_name:-$APP_NAME}"
    
    local launcher="$BIN_DIR/$app_key"
    local desktop="$APPS_DIR/${app_key}.desktop"
    
    # Create shell launcher wrapper
    cat > "$launcher" <<'LAUNCHER_EOF'
#!/bin/bash
# Auto-generated launcher for Wine Proton app
APP_KEY="%APP_KEY%"
WINE_DIR="%WINE_DIR%"
WINEPREFIX="%WINEPREFIX%"
PROTON_DIR="%PROTON_DIR%"
SETUP_SCRIPT="%SETUP_SCRIPT%"

export STEAM_COMPAT_DATA_PATH="$WINEPREFIX"
export STEAM_COMPAT_CLIENT_INSTALL_PATH="$WINE_DIR/steam-root"
export PROTON_LOG=1
export PROTON_LOG_DIR="$WINE_DIR"
export DXVK_HUD=0
export WINEDLLOVERRIDES="winemenubuilder.exe=d"
export VKD3D_SHADER_VERBOSE=0

# Read app config from registry by sourcing setup script functions only
if [ ! -f "$SETUP_SCRIPT" ]; then
    echo "Error: Setup script not found at $SETUP_SCRIPT" >&2
    exit 1
fi

# Load functions without executing main - use eval to parse everything except main
eval "$(grep -v '^main ' "$SETUP_SCRIPT" | grep -v '^# Execute main')"
parse_app_config "$APP_KEY" || exit 1

# Find exe in prefix (supports non-standard installation paths)
EXE_PATH=$(find_app_exe "$APP_KEY")
if [ -z "$EXE_PATH" ]; then
    echo "Error: $APP_KEY not found in prefix" >&2
    exit 1
fi

EXE_DIR=$(dirname "$EXE_PATH")
EXE_BIN=$(basename "$EXE_PATH")

cd "$EXE_DIR" || { echo "Error: Cannot cd to $EXE_DIR" >&2; exit 1; }

if [ -x "$PROTON_DIR/proton" ]; then
    "$PROTON_DIR/proton" run "$EXE_BIN" --no-sandbox \
        --disable-gpu-sandbox \
        --disable-software-rasterizer \
        --disable-dev-shm-usage \
        --disable-setuid-sandbox \
        --in-process-gpu >/dev/null 2>&1 &
else
    wine "$EXE_BIN" >/dev/null 2>&1 &
fi
LAUNCHER_EOF
    
    # Substitute variables in launcher
    # Get absolute path to this script
    local setup_script_path="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
    
    sed -i "s|%APP_KEY%|$app_key|g" "$launcher"
    sed -i "s|%WINE_DIR%|$WINE_DIR|g" "$launcher"
    sed -i "s|%WINEPREFIX%|$WINEPREFIX|g" "$launcher"
    sed -i "s|%PROTON_DIR%|$PROTON_DIR|g" "$launcher"
    sed -i "s|%SETUP_SCRIPT%|$setup_script_path|g" "$launcher"
    chmod +x "$launcher"
    
    # Create .desktop file
    cat > "$desktop" <<DESKTOP_EOF
[Desktop Entry]
Name=$display_name
Exec=$launcher
Type=Application
Categories=Game;
Terminal=false
StartupNotify=true
Icon=application-x-ms-dos-executable
DESKTOP_EOF
    
    chmod 644 "$desktop"
    
    # Update desktop database if available
    if command -v update-desktop-database &>/dev/null; then
        update-desktop-database "$APPS_DIR" >/dev/null 2>&1 || true
    fi
    
    print_success "Shortcut created: $display_name"
    return 0
}

# Remove desktop shortcut for an app
# Usage: remove_shortcut "app-key"
remove_shortcut() {
    local app_key="$1"
    
    parse_app_config "$app_key" || return 1
    
    local launcher="$BIN_DIR/$app_key"
    local desktop="$APPS_DIR/${app_key}.desktop"
    
    local removed=0
    if [ -f "$launcher" ]; then
        rm -f "$launcher"
        ((removed++))
    fi
    if [ -f "$desktop" ]; then
        rm -f "$desktop"
        ((removed++))
    fi
    
    if [ $removed -gt 0 ]; then
        print_success "Shortcut removed: $APP_NAME"
        
        # Update desktop database if available
        if command -v update-desktop-database &>/dev/null; then
            update-desktop-database "$APPS_DIR" >/dev/null 2>&1 || true
        fi
    fi
    
    return 0
}

# ============================================================================
# BATCH OPERATIONS
# ============================================================================

# Install all registered launchers
# Usage: install_all_launchers
install_all_launchers() {
    print_info "Installing all registered launchers..."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    
    check_proton || return 1
    
    local succeeded=0
    local failed=0
    local failed_apps=""
    
    for app_key in "${!APP_REGISTRY[@]}"; do
        print_info "Installing $app_key..."
        
        if install_app "$app_key"; then
            ((succeeded++))
        else
            ((failed++))
            failed_apps="$failed_apps\n  - $app_key"
        fi
    done
    
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    print_info "Installation Summary:"
    echo "  Successful: $succeeded"
    echo "  Failed: $failed"
    
    if [ $failed -gt 0 ]; then
        echo -e "  Failed apps:$failed_apps"
    fi
}

# ============================================================================
# WINE PREFIX MANAGEMENT
# ============================================================================

# Purge Wine prefix
purge() {
    print_warning "Purging Wine prefix at $WINEPREFIX..."
    if [ -d "$WINEPREFIX" ]; then
        rm -rf "$WINEPREFIX"
        print_success "Wine prefix purged"
    else
        print_info "Wine prefix not found (already clean)"
    fi
}

# Backup essential DLLs and packages
backup() {
    print_info "Backing up essential packages..."
    
    # Backup system DLLs
    if [ -d "$WINEPREFIX/drive_c/windows/system32" ]; then
        find "$WINEPREFIX/drive_c/windows/system32" -name "d3d*.dll" -o -name "vcruntime*.dll" -o -name "msvcp*.dll" -o -name "ucrtbase*.dll" 2>/dev/null | \
        xargs -I {} cp {} "$BACKUP_DIR/" 2>/dev/null || true
    fi
    
    # Backup winetricks cache
    if [ -d "$CACHE_DIR" ]; then
        for pkg in vcrun2019 d3dcompiler_47 dxvk vkd3d; do
            [ -d "$CACHE_DIR/$pkg" ] && cp -r "$CACHE_DIR/$pkg" "$BACKUP_DIR/" 2>/dev/null || true
        done
    fi
    
    print_success "Backup complete at $BACKUP_DIR"
}

# Restore from backup
restore() {
    print_info "Restoring from backup..."
    
    if [ ! -d "$BACKUP_DIR" ] || [ -z "$(ls -A "$BACKUP_DIR")" ]; then
        print_warning "No backup found, skipping restore"
        return 1
    fi
    
    [ -d "$WINEPREFIX/drive_c/windows/system32" ] && \
        cp -r "$BACKUP_DIR"/*.dll "$WINEPREFIX/drive_c/windows/system32/" 2>/dev/null || true
    
    print_success "Restored from backup"
    return 0
}

# Initialize Wine prefix with dependencies
init() {
    print_info "Initializing Wine prefix..."
    
    # Create enable-latest-version-check file to mute winetricks version check warning
    mkdir -p "${HOME}/.config/winetricks"
    touch "${HOME}/.config/winetricks/enable-latest-version-check"
    
    wineboot -u
    
    print_info "Installing Wine dependencies via winetricks..."
    # Comprehensive dependencies for game launchers (Lutris/Heroic standard robustness)
    # vcrun*: Visual C++ runtimes (required by all launchers)
    # d3dcompiler*, d3dx9-11: DirectX compilation and runtime (essential for graphics)
    # dxvk, vkd3d, d9vk: GPU acceleration layers
    # dotnet*, corefonts, gdiplus: .NET and fonts for UI
    # directmusic: Audio/MIDI subsystem (legacy games)
    # faudio, xact: Advanced audio (XAudio compatibility layer)
    # directplay, directshow: Legacy DirectX subsystems
    # physx: Physics engine (critical for modern launchers)
    # msctf: Text Services Framework
    # Suppress 64-bit prefix warnings
    WINETRICKS_LATEST_VERSION_CHECK=disabled winetricks -q vcrun2019 vcrun2015 vcrun2012 d3dcompiler_47 d3dcompiler_43 d3dx9 d3dx10_43 d3dx11_43 dxvk vkd3d d9vk corefonts dotnet48 dotnet472 gdiplus directmusic faudio xact directplay directshow physx msctf 2>&1 | grep -v "warning: You are using a 64-bit WINEPREFIX" | grep -v "Note that many verbs only install 32-bit" || true
    
    print_info "Configuring Wine environment..."
    wine winecfg /v win10 >/dev/null 2>&1 || true
    
    # Disable builtin D3D to use DXVK
    wine reg add "HKEY_CURRENT_USER\Software\Wine\Direct3D" /v "VideoMemorySize" /t REG_SZ /d "8192" /f >/dev/null 2>&1 || true
    wine reg add "HKEY_CURRENT_USER\Software\Wine\Direct3D" /v "CSMT" /t REG_SZ /d "enabled" /f >/dev/null 2>&1 || true
    
    print_success "Wine prefix initialized"
}

# Full setup: purge + init + install all apps from registry
full_setup() {
    print_info "Running full setup..."
    purge
    init
    backup
    
    print_info "Installing all registered launchers..."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    
    local succeeded=0
    local failed=0
    local failed_apps=""
    
    for app_key in "${!APP_REGISTRY[@]}"; do
        parse_app_config "$app_key" || continue
        
        print_info "Installing $app_key..."
        
        # Try local installer first, then download
        local local_installer=$(find_local_installer "$app_key" 2>/dev/null)
        if [ -n "$local_installer" ] && [ -f "$local_installer" ]; then
            print_info "Found local installer: $(basename "$local_installer")"
            if install_app "$app_key" "$local_installer"; then
                ((succeeded++))
            else
                ((failed++))
                failed_apps="$failed_apps\n  - $app_key"
            fi
        else
            # Fall back to download
            if install_app "$app_key"; then
                ((succeeded++))
            else
                ((failed++))
                failed_apps="$failed_apps\n  - $app_key"
            fi
        fi
    done
    
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    print_info "Full Setup Summary:"
    echo "  Successful: $succeeded"
    echo "  Failed: $failed"
    
    if [ $failed -gt 0 ]; then
        echo -e "  Failed apps:$failed_apps"
    fi
    
    print_success "Full setup complete"
}

# Quick setup: reinitialize dependencies WITHOUT purging (preserves installed apps)
# Quick setup: reinitialize dependencies + install remaining apps
quick_setup() {
    print_info "Running quick setup..."
    
    if [ ! -d "$WINEPREFIX" ]; then
        print_warning "Wine prefix not found, running full setup instead"
        full_setup
        return 0
    fi
    
    wineboot -u
    
    print_info "Reinstalling Wine dependencies via winetricks (non-destructive)..."
    # Comprehensive dependencies (same as init - reinstall only missing, preserve existing)
    # Includes all robustness libraries from Lutris/Heroic
    # Suppress 64-bit prefix warnings
    WINETRICKS_LATEST_VERSION_CHECK=disabled winetricks -q vcrun2019 vcrun2015 vcrun2012 d3dcompiler_47 d3dcompiler_43 d3dx9 d3dx10_43 d3dx11_43 dxvk vkd3d d9vk corefonts dotnet48 dotnet472 gdiplus directmusic faudio xact directplay directshow physx msctf 2>&1 | grep -v "warning: You are using a 64-bit WINEPREFIX" | grep -v "Note that many verbs only install 32-bit" || true
    
    print_info "Configuring Wine environment..."
    wine winecfg /v win10 >/dev/null 2>&1 || true
    
    # Ensure D3D/DXVK settings
    wine reg add "HKEY_CURRENT_USER\Software\Wine\Direct3D" /v "VideoMemorySize" /t REG_SZ /d "8192" /f >/dev/null 2>&1 || true
    wine reg add "HKEY_CURRENT_USER\Software\Wine\Direct3D" /v "CSMT" /t REG_SZ /d "enabled" /f >/dev/null 2>&1 || true
    
    # Now check for and install remaining apps
    print_info "Checking installed apps and installing remaining..."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    
    local succeeded=0
    local failed=0
    local skipped=0
    local failed_apps=""
    
    for app_key in "${!APP_REGISTRY[@]}"; do
        parse_app_config "$app_key" || continue
        
        # Check if already installed
        if find_app_exe "$app_key" >/dev/null 2>&1; then
            print_info "$APP_NAME already installed, skipping..."
            ((skipped++))
            continue
        fi
        
        print_info "Installing remaining app: $app_key..."
        
        # Try local installer first, then download
        local local_installer=$(find_local_installer "$app_key" 2>/dev/null)
        if [ -n "$local_installer" ] && [ -f "$local_installer" ]; then
            print_info "Found local installer: $(basename "$local_installer")"
            if install_app "$app_key" "$local_installer"; then
                ((succeeded++))
            else
                ((failed++))
                failed_apps="$failed_apps\n  - $app_key"
            fi
        else
            # Fall back to download
            if install_app "$app_key"; then
                ((succeeded++))
            else
                ((failed++))
                failed_apps="$failed_apps\n  - $app_key"
            fi
        fi
    done
    
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    print_info "Quick Setup Summary:"
    echo "  Newly installed: $succeeded"
    echo "  Already installed: $skipped"
    echo "  Failed: $failed"
    
    if [ $failed -gt 0 ]; then
        echo -e "  Failed apps:$failed_apps"
    fi
    
    print_success "Quick setup complete"
}

# Configure Wine drive mappings and file browser visibility
# Usage: configure_wine_drives [drive_letter] [mount_path]
# Example: ./setup configure-drives D /mnt/DATA-NVME
configure_wine_drives() {
    print_info "Configuring Wine drive mappings..."
    
    local dosdevices_dir="$WINEPREFIX/pfx/dosdevices"
    
    if [ ! -d "$dosdevices_dir" ]; then
        print_warning "Wine prefix not initialized yet, skipping drive configuration"
        return 1
    fi
    
    # If specific drive letter and path provided, create that symlink
    if [ -n "$1" ] && [ -n "$2" ]; then
        local drive_letter="${1:0:1}"
        local mount_path="$2"
        
        if [ ! -d "$mount_path" ]; then
            print_error "Mount path does not exist: $mount_path"
            return 1
        fi
        
        # Remove existing symlink if it exists
        if [ -L "$dosdevices_dir/${drive_letter}:" ]; then
            rm "$dosdevices_dir/${drive_letter}:"
            print_info "Removed existing ${drive_letter}: symlink"
        fi
        
        # Create new symlink
        ln -s "$mount_path" "$dosdevices_dir/${drive_letter}:"
        print_success "Created symlink: ${drive_letter}: -> $mount_path"
    fi
    
    # List all current drive mappings
    print_info "Current Wine drive mappings:"
    ls -la "$dosdevices_dir" | grep -E "^l" | awk '{print "  " $NF " -> " $11}'
    
    # Disable Z: drive to prevent /mnt auto-mounting
    if [ -L "$dosdevices_dir/z:" ]; then
        rm "$dosdevices_dir/z:"
        print_info "Removed Z: drive symlink (prevents /mnt auto-mounting)"
    fi
    
    # Refresh Wine to apply changes
    print_info "Refreshing Wine configuration..."
    wineserver -k >/dev/null 2>&1
    WINEPREFIX="$WINEPREFIX/pfx" wineboot -r >/dev/null 2>&1 || true
    
    print_success "Drive configuration complete. Restart Wine apps to see changes."
}

# Remove Z: drive and hide /mnt from Wine
fix_z_drive() {
    print_info "Removing Z: drive mount from Wine prefix..."
    
    if [ ! -d "$WINEPREFIX" ]; then
        print_warning "Wine prefix not found at $WINEPREFIX"
        return 1
    fi
    
    local dosdevices_dir="$WINEPREFIX/pfx/dosdevices"
    
    # Remove Z: symlink
    if [ -L "$dosdevices_dir/z:" ]; then
        rm "$dosdevices_dir/z:"
        print_success "Z: drive removed from dosdevices"
    fi
    
    # Also try via registry
    wine reg delete "HKEY_LOCAL_MACHINE\Software\Microsoft\Windows\CurrentVersion\Explorer\MountPoints2" /v Z: /f 2>/dev/null || true
    
    print_success "Z: drive removed (Wine will use only configured drive letters)"
    return 0
}

# Temporarily unmount Z: drive from Wine (prevents apps from seeing /mnt and reporting false disk space)
# Usage: ./setup unmount-z
unmount_z() {
    print_info "Unmounting Z: drive from Wine..."
    
    if [ ! -d "$WINEPREFIX" ]; then
        print_warning "Wine prefix not found at $WINEPREFIX"
        return 1
    fi
    
    local dosdevices_dir="$WINEPREFIX/pfx/dosdevices"
    
    # Backup current Z: symlink before unmounting it
    if [ -L "$dosdevices_dir/z:" ]; then
        local z_target=$(readlink "$dosdevices_dir/z:")
        echo "$z_target" > "$dosdevices_dir/.z_drive_backup"
        rm "$dosdevices_dir/z:"
        print_success "Z: drive unmounted"
    else
        print_warning "Z: drive not found (may already be unmounted)"
    fi
    
    # Suppress Wine serial number warnings for Z: in registry
    wine reg add "HKEY_LOCAL_MACHINE\System\CurrentControlSet\Services\VxD\SMCFS" /v "IgnoreSerialNumbers" /t REG_SZ /d "1" /f >/dev/null 2>&1 || true
    
    print_info "Wine no longer sees /mnt volumes (prevents disk space warnings)"
    return 0
}

# Restore Z: drive after unmounting
# Usage: ./setup mount-z
mount_z() {
    print_info "Mounting Z: drive in Wine..."
    
    if [ ! -d "$WINEPREFIX" ]; then
        print_warning "Wine prefix not found at $WINEPREFIX"
        return 1
    fi
    
    local dosdevices_dir="$WINEPREFIX/pfx/dosdevices"
    local backup_file="$dosdevices_dir/.z_drive_backup"
    
    # Restore Z: symlink from backup
    if [ -f "$backup_file" ]; then
        local z_target=$(cat "$backup_file")
        ln -s "$z_target" "$dosdevices_dir/z:"
        rm "$backup_file"
        print_success "Z: drive mounted"
    else
        # Default to root (standard Wine behavior)
        ln -s "/" "$dosdevices_dir/z:"
        print_success "Z: drive mounted (default: /)"
    fi
    
    return 0
}

# Suppress Wine Z: drive serial number and device label warnings
# These warnings appear in Wine logs when Z: drive permissions are restricted
# Usage: ./setup suppress-z-warnings
suppress_z_warnings() {
    print_info "Suppressing Wine Z: drive serial number warnings..."
    
    if [ ! -d "$WINEPREFIX" ]; then
        print_warning "Wine prefix not found at $WINEPREFIX"
        return 1
    fi
    
    # Suppress NTFS/device label warnings via registry
    wine reg add "HKEY_LOCAL_MACHINE\System\CurrentControlSet\Services\VxD\SMCFS" /v "IgnoreSerialNumbers" /t REG_SZ /d "1" /f >/dev/null 2>&1
    wine reg add "HKEY_LOCAL_MACHINE\System\CurrentControlSet\Control\FileSystem" /v "NtfsDisable8dot3NameCreation" /t REG_DWORD /d "1" /f >/dev/null 2>&1
    
    # Suppress mount point and device warnings
    wine reg add "HKEY_CURRENT_USER\Software\Wine\Explorer" /v "ShowHiddenFiles" /t REG_SZ /d "Y" /f >/dev/null 2>&1 || true
    
    print_success "Z: drive warnings suppressed in Wine registry"
    return 0
}

# Install Proton-GE
install_proton() {
    print_info "Installing Proton-GE..."
    
    mkdir -p "$PROTON_DIR"
    cd /tmp
    
    local PROTON_VERSION="GE-Proton9-18"
    local archive="${PROTON_VERSION}.tar.gz"
    
    print_info "Downloading Proton-GE $PROTON_VERSION..."
    
    if ! wget -q --show-progress "https://github.com/GloriousEggroll/proton-ge-custom/releases/download/${PROTON_VERSION}/${archive}"; then
        print_error "Failed to download Proton-GE"
        return 1
    fi
    
    print_info "Extracting Proton-GE..."
    tar -xf "$archive" -C "$PROTON_DIR" --strip-components=1
    rm -f "$archive"
    
    print_success "Proton-GE installed to $PROTON_DIR"
}

# ============================================================================
# HELP & USAGE
# ============================================================================

show_help() {
    cat <<'HELP_EOF'
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  Wine Proton Multi-Launcher Setup Script
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

USAGE:
  ./setup.sh <command> [options]

WINE PREFIX MANAGEMENT:
  purge                    Delete Wine prefix and start fresh
  backup                   Backup essential DLLs and packages
  restore                  Restore from backup
  init                     Initialize Wine prefix with dependencies
  full                     Complete setup: purge + init + install all apps from registry
  quick                    Quick setup: reinit deps + install remaining uninstalled apps
  install-proton           Download and install Proton-GE
  fix-z-drive              Remove Z: drive mount (forces Wine to use only configured drive letters)
  unmount-z                Temporarily unmount Z: drive from Wine (stops apps seeing /mnt, prevents disk space warnings)
  mount-z                  Mount Z: drive back in Wine
  suppress-z-warnings      Suppress Wine Z: drive serial number and device label warnings in logs
  configure-drives [D] [/path]  Configure Wine drive mappings (e.g., ./setup configure-drives D /mnt/DATA-NVME)

APP MANAGEMENT:
  list                     Show all registered launchers and install status
  list-installers          Show available installers in ./installers directory
  install <app-key>        Install a launcher (e.g., ./setup.sh install ea-desktop)
  install <app-key> <path> Install with custom installer path
  install-all              Install all registered launchers
  uninstall <app-key>      Remove a launcher from prefix
  launch <app-key>         Launch an installed app with Proton/Wine
  
SHORTCUT MANAGEMENT:
  install-shortcut <key>   Create desktop launcher for an app
  remove-shortcut <app-key> Remove desktop shortcut

AVAILABLE LAUNCHERS:
  ea-desktop               EA Desktop (Origin)
  gog-galaxy               GOG Galaxy
  epic-games               Epic Games Launcher
  ubisoft-connect          Ubisoft Connect
  amazon-games             Amazon Games
  legacy-games             Legacy Games

EXAMPLES:
  # Initial setup
  ./setup.sh install-proton
  ./setup.sh full

  # Install a launcher
  ./setup.sh install gog-galaxy

  # Install with custom installer
  ./setup.sh install ea-desktop /path/to/EAappInstaller.exe

  # Launch an app
  ./setup.sh launch gog-galaxy

  # Create desktop shortcut
  ./setup.sh install-shortcut ea-desktop

  # Install all launchers
  ./setup.sh install-all

  # List installed apps
  ./setup.sh list

CONFIGURATION:
  Edit APP_REGISTRY array in this script to add new launchers.
  Format: [app-key]="name|exe-path|url|uninstall-path1|uninstall-path2|..."

DIRECTORIES:
  Wine prefix:  $WINEPREFIX
  Proton:       $PROTON_DIR
  Cache:        $CACHE_DIR
  Backups:      $BACKUP_DIR
  Shortcuts:    $APPS_DIR

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
HELP_EOF
}

# ============================================================================
# MAIN COMMAND ROUTER
# ============================================================================

main() {
    local command="${1:-help}"
    
    case "$command" in
        # Wine prefix management
        purge)              purge ;;
        backup)             backup ;;
        restore)            restore ;;
        init)               init ;;
        full)               full_setup ;;
        quick)              quick_setup ;;
        install-proton)     install_proton ;;
        fix-z-drive)        fix_z_drive ;;
        unmount-z)          unmount_z ;;
        mount-z)            mount_z ;;
        suppress-z-warnings) suppress_z_warnings ;;
        configure-drives)   configure_wine_drives ;;
        
        # App management (registry-based)
        list)               list_apps ;;
        list-installers)    list_installers ;;
        install)            install_app "$2" "$3" ;;
        install-all)        install_all_launchers ;;
        uninstall)          uninstall_app "$2" ;;
        launch)             launch_app "$2" ;;
        
        # Shortcut management
        install-shortcut)   create_shortcut "$2" "$3" ;;
        remove-shortcut)    remove_shortcut "$2" ;;
        
        # Help
        help|-h|--help)     show_help ;;
        
        # Unknown command
        *)
            print_error "Unknown command: $command"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

# Execute main function with all arguments
main "$@"
